{
  "name": "@chrona/openclaw-plugin-structured-result",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "bun build ./src/index.ts --target=node --format=esm --external openclaw/plugin-sdk/plugin-entry --outfile ./dist/index.js && cp ./openclaw.plugin.json ./dist/openclaw.plugin.json",
    "test": "vitest run ./src/index.test.ts"
  }
}
