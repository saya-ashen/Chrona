{
  "name": "@chrona-org/cli",
  "version": "0.1.3",
  "description": "Chrona — AI-native task control plane for planning, scheduling, and observing runtime-powered work",
  "license": "MIT",
  "type": "module",
  "bin": {
    "chrona": "./dist/cli.js"
  },
  "files": [
    "dist",
    "apps/web/dist",
    "prisma/schema.prisma",
    "prisma/migrations",
    ".env.example"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/saya-ashen/Chrona.git"
  },
  "keywords": [
    "ai",
    "agent",
    "dashboard",
    "task-management",
    "cqrs",
    "event-sourcing",
    "vite",
    "openclaw"
  ],
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.11"
  },
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:web": "bun run --cwd apps/web dev --host 0.0.0.0",
    "build": "bun run --cwd apps/web build",
    "build:full": "bun run build && bun run server:bundle-check",
    "build:npm": "bun run scripts/build-npm.ts",
    "start": "bun run server:start",
    "typecheck": "bunx tsc --noEmit --pretty false",
    "server:dev": "bun --watch apps/server/src/index.bun.ts",
    "server:start": "bun run apps/server/src/index.bun.ts",
    "server:bundle-check": "test -f apps/web/dist/index.html",
    "lint": "eslint .",
    "check:boundaries": "bunx dependency-cruiser --config .dependency-cruiser.cjs apps packages",
    "test:web": "vitest run --coverage",
    "test:watch": "vitest",
    "test:api": "bun test apps/server/src/__tests__/api/ apps/server/src/routes/__tests__/",
    "test:bridge": "bun test apps/server/src/__tests__/bridge/ packages/providers/openclaw/bridge/src/ packages/providers/openclaw/integration/src/transport/",
    "test:bun": "bun run scripts/run-bun-tests.ts",
    "test:e2e": "playwright test",
    "demo:readme-gif": "bun scripts/demo/readme-gif.ts",
    "db:seed": "bun prisma/seed.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "setup": "bun run db:generate && bun run db:seed",
    "probe:openclaw": "bun scripts/openclaw/probe.ts",
    "cli:build": "bun build packages/cli/src/main.ts --outdir=packages/cli/dist --target=bun",
    "prepublishOnly": "bun run build && bun run build:npm",
    "build:binaries": "bun run scripts/build-binaries.ts",
    "build:binary:linux-x64": "bun run scripts/build-binaries.ts --target linux-x64",
    "build:binary:linux-arm64": "bun run scripts/build-binaries.ts --target linux-arm64",
    "build:binary:darwin-x64": "bun run scripts/build-binaries.ts --target darwin-x64",
    "build:binary:darwin-arm64": "bun run scripts/build-binaries.ts --target darwin-arm64",
    "build:binary:windows-x64": "bun run scripts/build-binaries.ts --target windows-x64"
  },
  "dependencies": {
    "@prisma/client": "7.8.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "hono": "^4.9.6",
    "prisma-adapter-bun-sqlite": "^0.7.1"
  },
  "devDependencies": {
    "@base-ui/react": "^1.3.0",
    "@dagrejs/dagre": "^1.1.4",
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "eslint": "^9",
    "jsdom": "^29.0.2",
    "lucide-react": "^1.7.0",
    "playwright": "^1.59.1",
    "prisma": "7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "^7.9.4",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.1.3",
    "zod": "^4.3.6"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "@prisma/engines",
    "esbuild",
    "prisma",
    "sharp",
    "unrs-resolver"
  ],
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/*/*",
    "packages/*/*/*"
  ]
}
