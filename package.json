{
  "name": "agent-dashboard",
  "version": "0.1.0",
  "description": "AI-Native Task Control Plane — Plan, schedule, and observe AI-runtime-powered work",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/AgentDashboard.git"
  },
  "keywords": ["ai", "agent", "dashboard", "task-management", "cqrs", "event-sourcing", "nextjs", "openclaw"],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:openclaw:integration": "OPENCLAW_INTEGRATION_TESTS=1 vitest run src/modules/openclaw/__tests__/client.integration.test.ts",
    "test:e2e": "playwright test",
    "db:seed": "bun prisma/seed.ts",
    "probe:openclaw": "bun scripts/openclaw/probe.ts",
    "agentdash": "bun src/cli/index.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "class-variance-authority": "^0.7.1",
    "cli-table3": "^0.6.5",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "prisma-adapter-bun-sqlite": "^0.7.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "prisma": "^7.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "@prisma/engines",
    "better-sqlite3",
    "esbuild",
    "prisma",
    "sharp",
    "unrs-resolver"
  ]
}
