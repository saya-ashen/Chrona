{
  "name": "chrona",
  "version": "0.1.0",
  "description": "Chrona — AI-native task control plane for planning, scheduling, and observing runtime-powered work",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/Chrona.git"
  },
  "keywords": [
    "ai",
    "agent",
    "dashboard",
    "task-management",
    "cqrs",
    "event-sourcing",
    "vite",
    "openclaw"
  ],
  "scripts": {
    "dev": "bun run dev:full",
    "dev:web": "bun run --cwd apps/web dev --host 0.0.0.0",
    "dev:full": "bunx concurrently -k -n web,server \"bun run dev:web\" \"bun run server:dev:bun\"",
    "build": "bun run --cwd apps/web build",
    "build:full": "bun run build && bun run server:bundle-check",
    "start": "bun run server:start:bun",
    "typecheck": "bunx tsc --noEmit --pretty false",
    "server:dev": "tsx watch apps/server/src/index.ts",
    "server:dev:bun": "bun run apps/server/src/index.bun.ts",
    "server:start": "tsx apps/server/src/index.ts",
    "server:start:bun": "bun run apps/server/src/index.bun.ts",
    "server:bundle-check": "test -f apps/web/dist/index.html",
    "lint": "eslint .",
    "check:boundaries": "bunx dependency-cruiser --config .dependency-cruiser.cjs src packages",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:openclaw:integration": "OPENCLAW_INTEGRATION_TESTS=1 vitest run src/modules/openclaw/__tests__/client.integration.test.ts",
    "test:e2e": "playwright test",
    "demo:readme-gif": "bun scripts/demo/readme-gif.ts",
    "db:seed": "bun prisma/seed.ts",
    "probe:openclaw": "bun scripts/openclaw/probe.ts",
    "openclaw:bridge": "bun packages/providers/openclaw/bridge/src/index.ts",
    "bridge:openclaw": "bun packages/providers/openclaw/bridge/src/index.ts",
    "openclaw:plugin:build": "bun run --cwd packages/providers/openclaw/plugin-structured-result build",
    "openclaw:plugin:install": "bun scripts/openclaw/install-structured-plugin.ts",
    "chrona": "bun packages/common/cli/src/index.ts",
    "agentdash": "bun packages/common/cli/src/index.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@xyflow/react": "^12.10.2",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "hono": "^4.9.6",
    "lucide-react": "^1.7.0",
    "prisma-adapter-bun-sqlite": "^0.7.1",
    "react-router-dom": "^7.9.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "@eslint/js": "^9.38.0",
    "eslint": "^9",
    "typescript-eslint": "^8.46.1",
    "jsdom": "^29.0.2",
    "concurrently": "^9.1.2",
    "playwright": "^1.59.1",
    "prisma": "^7.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "@prisma/engines",
    "better-sqlite3",
    "esbuild",
    "prisma",
    "sharp",
    "unrs-resolver"
  ],
  "workspaces": [
    "packages/*",
    "packages/*/*",
    "packages/*/*/*"
  ]
}
