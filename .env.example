# ─── Database ───
DATABASE_URL="file:./prisma/dev.db"

# ─── OpenClaw Runtime ───
# Mode: "bridge" (recommended), "live" (WebSocket gateway), or "mock" (testing)
OPENCLAW_MODE="mock"

# CLI Bridge (when OPENCLAW_MODE=bridge)
# OPENCLAW_BRIDGE_URL="http://localhost:7677"
# OPENCLAW_TIMEOUT=300

# WebSocket Gateway (when OPENCLAW_MODE=live)
# OPENCLAW_GATEWAY_URL="ws://localhost:3001/gateway"
# OPENCLAW_AUTH_TOKEN=""
# OPENCLAW_AUTH_PASSWORD=""
# OPENCLAW_IDENTITY_DIR=""
# OPENCLAW_BASE_URL=""

# ─── AI Providers ───
# Configure AI clients via the Settings > AI Clients page, or set defaults here:
# AI_PROVIDER_API_KEY=""
# AI_PROVIDER_MODEL=""

# ─── Frontend ───
NEXT_PUBLIC_WORK_POLL_INTERVAL_MS="10000"
