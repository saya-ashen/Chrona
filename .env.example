# ─── Database ───
DATABASE_URL="file:./prisma/dev.db"

# ─── OpenClaw Runtime ───
# Mode: "bridge" (recommended) or "mock" (testing)
OPENCLAW_MODE="mock"

# CLI Bridge runtime
# OPENCLAW_BRIDGE_URL="http://localhost:7677"
# OPENCLAW_TIMEOUT=300

# ─── AI Providers ───
# Configure AI clients via the Settings > AI Clients page, or set defaults here:
# AI_PROVIDER_API_KEY=""
# AI_PROVIDER_MODEL=""

# ─── Frontend ───
NEXT_PUBLIC_WORK_POLL_INTERVAL_MS="10000"
