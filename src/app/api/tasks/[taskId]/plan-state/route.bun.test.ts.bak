import { afterEach, beforeEach, describe, expect, it, mock } from "bun:test";

const getAcceptedTaskPlanGraph = mock();
const getLatestTaskPlanGraph = mock();
const isTaskPlanGenerationRunning = mock();

mock.module("@/modules/tasks/task-plan-graph-store", () => ({
  getAcceptedTaskPlanGraph,
  getLatestTaskPlanGraph,
}));

mock.module("@/modules/commands/task-plan-generation-registry", () => ({
  isTaskPlanGenerationRunning,
}));

describe("GET /api/tasks/[taskId]/plan-state", () => {
  beforeEach(() => {
    getAcceptedTaskPlanGraph.mockReset();
    getLatestTaskPlanGraph.mockReset();
    isTaskPlanGenerationRunning.mockReset();
  });

  afterEach(() => {
    getAcceptedTaskPlanGraph.mockReset();
    getLatestTaskPlanGraph.mockReset();
    isTaskPlanGenerationRunning.mockReset();
  });

  it("returns idle when no plan exists and no generation is running", async () => {
    getAcceptedTaskPlanGraph.mockResolvedValue(null);
    getLatestTaskPlanGraph.mockResolvedValue(null);
    isTaskPlanGenerationRunning.mockReturnValue(false);

    const { GET } = await import("./route");
    const response = await GET(new Request("http://localhost/api/tasks/task-1/plan-state"), {
      params: Promise.resolve({ taskId: "task-1" }),
    });

    expect(response.status).toBe(200);
    expect(await response.json()).toEqual({
      taskId: "task-1",
      aiPlanGenerationStatus: "idle",
      savedAiPlan: null,
    });
  });

  it("returns generating when the backend registry reports an in-flight job", async () => {
    getAcceptedTaskPlanGraph.mockResolvedValue(null);
    getLatestTaskPlanGraph.mockResolvedValue({
      id: "plan-draft-1",
      status: "draft",
      prompt: null,
      revision: 2,
      summary: "draft plan",
      updatedAt: "2026-04-25T14:30:00.000Z",
      plan: { id: "plan-draft-1", nodes: [], edges: [] },
    });
    isTaskPlanGenerationRunning.mockReturnValue(true);

    const { GET } = await import("./route");
    const response = await GET(new Request("http://localhost/api/tasks/task-1/plan-state"), {
      params: Promise.resolve({ taskId: "task-1" }),
    });

    expect(response.status).toBe(200);
    expect(await response.json()).toMatchObject({
      taskId: "task-1",
      aiPlanGenerationStatus: "generating",
      savedAiPlan: {
        id: "plan-draft-1",
        status: "draft",
        revision: 2,
      },
    });
  });

  it("prefers the accepted plan over the latest draft and reports accepted status", async () => {
    getAcceptedTaskPlanGraph.mockResolvedValue({
      id: "plan-accepted-1",
      status: "accepted",
      prompt: "prompt",
      revision: 4,
      summary: "accepted plan",
      updatedAt: "2026-04-25T14:35:00.000Z",
      plan: { id: "plan-accepted-1", nodes: [], edges: [] },
    });
    getLatestTaskPlanGraph.mockResolvedValue({
      id: "plan-draft-2",
      status: "draft",
      prompt: null,
      revision: 5,
      summary: "new draft",
      updatedAt: "2026-04-25T14:40:00.000Z",
      plan: { id: "plan-draft-2", nodes: [], edges: [] },
    });
    isTaskPlanGenerationRunning.mockReturnValue(false);

    const { GET } = await import("./route");
    const response = await GET(new Request("http://localhost/api/tasks/task-1/plan-state"), {
      params: Promise.resolve({ taskId: "task-1" }),
    });

    expect(response.status).toBe(200);
    expect(await response.json()).toMatchObject({
      taskId: "task-1",
      aiPlanGenerationStatus: "accepted",
      savedAiPlan: {
        id: "plan-accepted-1",
        status: "accepted",
        prompt: "prompt",
        revision: 4,
        summary: "accepted plan",
      },
    });
    expect(getLatestTaskPlanGraph).not.toHaveBeenCalled();
  });
});
