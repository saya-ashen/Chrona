import { NextResponse } from "next/server";
import { decideScheduleProposal } from "@/modules/commands/decide-schedule-proposal";

/**
 * POST /api/schedule/proposals/decision — Accept or reject a schedule proposal.
 * Body: { proposalId, decision, resolutionNote? }
 */
export async function POST(request: Request) {
  try {
    const body = await request.json();
    const proposalId = typeof body.proposalId === "string" ? body.proposalId : "";
    const decision = body.decision;

    if (!proposalId) {
      return NextResponse.json({ error: "proposalId is required" }, { status: 400 });
    }

    if (decision !== "Accepted" && decision !== "Rejected") {
      return NextResponse.json(
        { error: 'decision must be "Accepted" or "Rejected"' },
        { status: 400 },
      );
    }

    const result = await decideScheduleProposal({
      proposalId,
      decision,
      resolutionNote:
        typeof body.resolutionNote === "string" ? body.resolutionNote : undefined,
    });

    return NextResponse.json(result);
  } catch (error) {
    const message =
      error instanceof Error ? error.message : "Failed to resolve schedule proposal";
    console.error("POST /api/schedule/proposals/decision error:", message);

    if (message.includes("not found") || message.includes("No 'ScheduleProposal' record")) {
      return NextResponse.json({ error: "Schedule proposal not found" }, { status: 404 });
    }

    return NextResponse.json({ error: message }, { status: 400 });
  }
}
