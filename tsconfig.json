{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "paths": {
      "@/generated/prisma/*": ["./packages/db/src/generated/prisma/*"],
      "@/modules/*": ["./packages/runtime/src/modules/*"],
      "@/lib/db": ["./packages/db/src/db.ts"],
      "@/lib/logger": ["./apps/web/src/lib/logger.ts"],
      "@/lib/demo-artifacts": ["./packages/db/src/demo-artifacts.ts"],
      "@/*": ["./apps/web/src/*"],
      "@web/*": ["./apps/web/src/*"],
      "@server/*": ["./apps/server/src/*"],
      "@chrona/runtime-core": ["./packages/runtime-core/src/index.ts"],
      "@chrona/runtime-core/*": ["./packages/runtime-core/src/*"],
      "@chrona/i18n": ["./packages/i18n/src/locale.ts"],
      "@chrona/i18n/*": ["./packages/i18n/src/*"],
      "@chrona/openclaw-integration": ["./packages/providers/openclaw/integration/src/index.ts"],
      "@chrona/openclaw-integration/*": ["./packages/providers/openclaw/integration/src/*"],
      "@chrona/ai-features": ["./packages/ai-features/src/index.ts"],
      "@chrona/ai-features/*": ["./packages/ai-features/src/*"],
      "@chrona/domain": ["./packages/domain/src/index.ts"],
      "@chrona/domain/*": ["./packages/domain/src/*"],
      "@chrona/contracts": ["./packages/contracts/src/index.ts"],
      "@chrona/contracts/*": ["./packages/contracts/src/*"],
      "@chrona/db": ["./packages/db/src/index.ts"],
      "@chrona/db/*": ["./packages/db/src/*"],
      "@chrona/runtime": ["./packages/runtime/src/index.ts"],
      "@chrona/runtime/*": ["./packages/runtime/src/*"],
    "@chrona/openclaw-bridge": ["./packages/providers/openclaw/bridge/src/server.ts"],
      "@chrona/openclaw-bridge/*": ["./packages/providers/openclaw/bridge/src/*"],
      "@chrona/providers-core": ["./packages/providers/core/src/index.ts"],
      "@chrona/providers-core/*": ["./packages/providers/core/src/*"],
      "@chrona/web/*": ["./apps/web/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts"
  ],
  "exclude": ["node_modules", "e2e", ".worktrees", "result", "dist"]
}
