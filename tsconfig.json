{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "types": ["bun", "node"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/generated/prisma/*": ["./packages/db/src/generated/prisma/*"],
      "@/modules/*": ["./packages/runtime/src/modules/*"],
      "@/components/*": ["./apps/web/src/components/*"],
      "@/hooks/*": ["./apps/web/src/hooks/*"],
      "@/i18n/*": ["./apps/web/src/i18n/*"],
      "@/lib/db": ["./packages/db/src/legacy-lib/db.ts"],
      "@/lib/logger": ["./apps/web/src/lib/logger.ts"],
      "@/lib/demo-artifacts": ["./packages/db/src/legacy-lib/demo-artifacts.ts"],
      "@/lib/*": ["./apps/web/src/lib/*"],
      "@/*": ["./src/*"],
      "@web/*": ["./apps/web/src/*"],
      "@server/*": ["./apps/server/src/*"],
      "@chrona/runtime-core": ["./packages/common/runtime-core/src/index.ts"],
      "@chrona/runtime-core/*": ["./packages/common/runtime-core/src/*"],
      "@chrona/openclaw-integration": ["./packages/providers/openclaw/integration/src/index.ts"],
      "@chrona/openclaw-integration/*": ["./packages/providers/openclaw/integration/src/*"],
      "@chrona/ai-features": ["./packages/common/ai-features/src/index.ts"],
      "@chrona/ai-features/*": ["./packages/common/ai-features/src/*"],
      "@chrona/domain": ["./packages/domain/src/index.ts"],
      "@chrona/domain/*": ["./packages/domain/src/*"],
      "@chrona/contracts": ["./packages/contracts/src/index.ts"],
      "@chrona/contracts/*": ["./packages/contracts/src/*"],
      "@chrona/db": ["./packages/db/src/index.ts"],
      "@chrona/db/*": ["./packages/db/src/*"],
      "@chrona/runtime": ["./packages/runtime/src/index.ts"],
      "@chrona/runtime/*": ["./packages/runtime/src/*"],
    "@chrona/openclaw-bridge": ["./packages/providers/openclaw/bridge/src/server.ts"],
      "@chrona/openclaw-bridge/*": ["./packages/providers/openclaw/bridge/src/*"],
      "@chrona/web/*": ["./apps/web/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
